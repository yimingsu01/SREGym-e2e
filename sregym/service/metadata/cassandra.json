{
    "Name": "Cassandra",
    "Namespace": "cassandra",
    "Desc": "Apache Cassandra distributed NoSQL database deployed via the K8ssandra operator (cass-operator). Provides a multi-node Cassandra cluster for testing distributed database bugs.",
    "Supported Operations": [
        "CQL queries (SELECT, INSERT, UPDATE, DELETE)",
        "Schema management (CREATE/ALTER/DROP TABLE, KEYSPACE)",
        "Secondary index queries",
        "Lightweight transactions (IF NOT EXISTS / IF conditions)",
        "Compaction and repair operations"
    ],
    "K8ssandra Config": {
        "operator_namespace": "k8ssandra-operator",
        "operator_helm_repo": "k8ssandra",
        "operator_helm_repo_url": "https://helm.k8ssandra.io/stable",
        "operator_chart": "k8ssandra/k8ssandra-operator",
        "cluster_name": "sregym-cassandra",
        "datacenter_name": "dc1",
        "cluster_size": 3,
        "cassandra_version": "4.1.7"
    }
}
